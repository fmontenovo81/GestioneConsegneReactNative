{
  "expo": {
    "name": "Gestione Consegne",
    "slug": "gestioneconsegne",
    "version": "1.0.0",
    "scheme": "gestioneconsegne",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "it.entersrl.gestioneconsegne"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "it.entersrl.gestioneconsegne",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "NFC",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Questa app usa la posizione GPS per tracciare le consegne.",
          "locationWhenInUsePermission": "Questa app usa la posizione GPS per tracciare le consegne."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98d78e0d-d5dd-49f2-81eb-8fafa4628145"
      }
    },
    "owner": "entersrl"
  }
}
